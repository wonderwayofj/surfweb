{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "http-server",
      "runtimeExecutable": "/opt/homebrew/bin/node",
      "runtimeArgs": ["-e", "require('http').createServer((q,r)=>{const fs=require('fs'),p=require('path'),u=q.url==='/'?'/index.html':decodeURIComponent(q.url),f=p.join('/Users/janvitek/Desktop/SurfWeb',u),m={'.html':'text/html','.js':'text/javascript','.css':'text/css','.jpg':'image/jpeg','.jpeg':'image/jpeg','.png':'image/png','.mp4':'video/mp4','.svg':'image/svg+xml'};fs.readFile(f,(e,d)=>{if(e){r.writeHead(404);r.end('Not found')}else{r.writeHead(200,{'Content-Type':m[p.extname(f).toLowerCase()]||'application/octet-stream'});r.end(d)}})}).listen(8000)"],
      "port": 8000
    }
  ]
}
